class Solution(object):
    def isPalindrome(self, s):
        string = s.lower()
        clean = ''.join(char for char in string if char.isalnum())
        check = False
        length = len(clean)    
        for i in range(length//2):
            
            if clean[i] != clean[length - i - 1]:
                return False
        
        return True
